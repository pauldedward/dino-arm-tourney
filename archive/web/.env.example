# ─── Supabase ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER prefix with NEXT_PUBLIC_. Used by /api/* and seed script.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Cloudflare R2 (S3-compatible) ─────────────────────────────────────────
# Endpoint = https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BUCKET=dino-arm-tourney-public
R2_PRIVATE_BUCKET=dino-arm-tourney-media
# Public bucket served via Cloudflare's r2.dev or a custom domain.
# e.g. https://pub-xxxxxxxx.r2.dev   or   https://media.example.com
R2_PUBLIC_BASE_URL=

# ─── App ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Razorpay (stretch goal §6.1) ─────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
